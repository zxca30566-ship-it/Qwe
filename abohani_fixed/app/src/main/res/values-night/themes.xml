<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AboHani" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/background_dark</item>
        <item name="colorPrimaryContainer">#1A3D16</item>
        <item name="colorOnPrimaryContainer">#B8E6B0</item>
        <item name="colorSecondary">#BFA898</item>
        <item name="colorOnSecondary">@color/background_dark</item>
        <item name="colorSecondaryContainer">#3D2E22</item>
        <item name="colorOnSecondaryContainer">#F0E0D0</item>
        <item name="colorError">#F2B8B5</item>
        <item name="colorOnError">#601410</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorSurfaceVariant">#3A2E28</item>
        <item name="colorOnSurfaceVariant">#BFA898</item>
        <item name="colorOutline">#5C4E44</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:layoutDirection">rtl</item>
    </style>

    <style name="Theme.AboHani.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.AboHani</item>
    </style>
</resources>
